# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
APP_BASE_URL=http://localhost:8000

# PostgreSQL
DB_NAME=email_campaign
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email — Mailgun SMTP sandbox
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=postmaster@your-sandbox.mailgun.org
EMAIL_HOST_PASSWORD=your-mailgun-smtp-password
DEFAULT_FROM_EMAIL=MikeLegal Campaigns <postmaster@your-sandbox.mailgun.org>

# Set to True to skip real SMTP and log a simulated send instead
USE_DUMMY_EMAIL=False

# Hour (UTC, 0-23) at which Celery Beat fires the daily campaign send
CAMPAIGN_SEND_HOUR=8
